#!/usr/bin/env bash

set -euo pipefail

REVIEWERS_MAPPING_FILE="$DOTFILES_DIR/reviewers.txt"

# Must provide at least one approver, can be comma separated or multiple arguments
if [[ $# -eq 0 ]]; then
    echo ""
    exit 0
fi

# Get the reviewers from all arguments, split them by comma and trim any whitespace
reviewers=()
for arg in "$@"; do
    # Split the argument by comma and trim any whitespace
    IFS=',' read -r -a reviewers_elements <<< "$arg"
    for approver in "${reviewers_elements[@]}"; do
        approver=$(echo "$approver" | xargs)
        reviewers+=("$approver")
    done
done

# End early if no reviewers were provided
if [[ ${#reviewers[@]} -eq 0 ]]; then
    echo ""
    exit 0
fi

# Function to lookup a reviewer mapping
lookup_reviewer() {
    local key="$1"
    
    while IFS= read -r line; do
        # Skip empty lines and comments
        if [[ -z "$line" || "$line" =~ ^# ]]; then
            continue
        fi
        
        # Split the line into key and value
        IFS='=' read -r file_key file_value <<< "$line"
        
        # If we found a match, return the value
        if [[ "$file_key" == "$key" ]]; then
            echo "$file_value"
            return 0
        fi
    done < "$REVIEWERS_MAPPING_FILE"
    
    # If no match found, return the original key
    echo "$key"
}

# Create a new array to store the expanded reviewers
expanded_reviewers=()

# For each reviewer, look up their mapping and expand
for reviewer in "${reviewers[@]}"; do
    mapped_value=$(lookup_reviewer "$reviewer")
    
    # If the mapped value contains commas, split it
    if [[ "$mapped_value" == *","* ]]; then
        IFS=',' read -r -a mapped_values <<< "$mapped_value"
        for mapped_reviewer in "${mapped_values[@]}"; do
            # Trim whitespace and add to expanded array
            mapped_reviewer=$(echo "$mapped_reviewer" | xargs)
            expanded_reviewers+=("$mapped_reviewer")
        done
    else
        # Single value, just add it (trimmed)
        mapped_value=$(echo "$mapped_value" | xargs)
        expanded_reviewers+=("$mapped_value")
    fi
done

# Replace the original reviewers array with the expanded one
reviewers=("${expanded_reviewers[@]}")

# Remove duplicates from the reviewers array and print as comma separated values
echo "${reviewers[@]}" | tr ' ' '\n' | sort -u | tr '\n' ',' | sed 's/,$//' && echo 