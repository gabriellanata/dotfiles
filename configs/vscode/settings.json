        "**/.next/**": true,
        "**/bazel-*/**": true,
        "**/DerivedData/**": true,
        "**/external/**": true,
        "**/__pycache__/**": true,
        "**/venv/**": true,
        "**/.mypy_cache/**": true,
        "**/coverage/**": true,
        "**/.cache/**": true,
        "**/.gradle/**": true,
        "**/Pods/**": true,
