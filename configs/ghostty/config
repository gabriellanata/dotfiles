# Escape with backtick
keybind = grave_accent=text:\x03

# Quick terminal (global)
keybind = global:ctrl+grave_accent=toggle_quick_terminal

# splits
keybind = super+d=new_split:down
keybind = super+r=new_split:right

# split navigation 
keybind = super+shift+w=goto_split:top
keybind = super+shift+a=goto_split:left
keybind = super+shift+s=goto_split:bottom
keybind = super+shift+d=goto_split:right
keybind = super+shift+up=goto_split:top
keybind = super+shift+left=goto_split:left
keybind = super+shift+down=goto_split:bottom
keybind = super+shift+right=goto_split:right

# Tmux cmd + num tabbing 
# keybind = super+1=text:\x021
# keybind = super+2=text:\x022
# keybind = super+3=text:\x023
# keybind = super+4=text:\x024
# keybind = super+5=text:\x025
# keybind = super+6=text:\x026
# keybind = super+7=text:\x027
# keybind = super+8=text:\x028
# keybind = super+9=text:\x029

# Appearance
theme = catppuccin-mocha
font-thicken = true

# macOS-specific settings
macos-titlebar-style = tabs
macos-option-as-alt = true
macos-titlebar-proxy-icon = visible

# Shell integration
shell-integration-features = no-title
shell-integration = zsh

# extras
# title = "Ghostty"
quick-terminal-screen = mouse
focus-follows-mouse = true
confirm-close-surface = false
cursor-click-to-move = true
copy-on-select = clipboard
link-url = true
keybind = shift+enter=text:\n
